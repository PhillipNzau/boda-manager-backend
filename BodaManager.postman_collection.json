{
  "info": {
    "name": "Boda Manager API - Full",
    "_postman_id": "boda-manager-api-full",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) pm.environment.set(\"token\", jsonData.token);",
                  "if (jsonData.refresh_token) pm.environment.set(\"refresh_token\", jsonData.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/request-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Riders",
      "item": [
        {
          "name": "List Riders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/riders"
          }
        },
        {
          "name": "Create Rider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/riders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Rider\",\n  \"phone_number\": \"0712345678\",\n  \"license_no\": \"DL12345\",\n  \"daily_target\": 500,\n  \"motorcycle_id\": \"{{motorcycle_id}}\"\n}"
            }
          }
        },
        {
          "name": "Delete Rider",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/riders/{{rider_id}}"
          }
        }
      ]
    },
    {
      "name": "Motorcycles",
      "item": [
        {
          "name": "List Motorcycles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/motorcycles"
          }
        },
        {
          "name": "Create Motorcycle",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/motorcycles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registration_number\": \"KMDX 123Q\",\n  \"model\": \"Bajaj Boxer\",\n  \"year\": 2024\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Rides",
      "item": [
        {
          "name": "Log Ride",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/rides",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rider_id\": \"{{rider_id}}\",\n  \"date\": \"2024-05-11\",\n  \"trips\": 12,\n  \"income\": 2000,\n  \"fuel_cost\": 500,\n  \"expenses\": 50,\n  \"notes\": \"Productive shift\"\n}"
            }
          }
        },
        {
          "name": "List Rides",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/rides"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments"
          }
        },
        {
          "name": "Get Payment Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments/{{payment_id}}"
          }
        },
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rider_id\": \"{{rider_id}}\",\n  \"amount\": 500,\n  \"method\": \"mpesa\",\n  \"expected_amount\": 500,\n  \"motorcycle_id\": \"{{motorcycle_id}}\",\n  \"date\": \"{{$isoTimestamp}}\"\n}"
            }
          }
        },
        {
          "name": "Delete Payment",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments/{{payment_id}}"
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "List Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/expenses"
          }
        },
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/expenses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motorcycle_id\": \"{{motorcycle_id}}\",\n  \"category\": \"repair\",\n  \"description\": \"Engine oil change\",\n  \"amount\": 1200,\n  \"date\": \"{{$isoTimestamp}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics & Dashboard",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/dashboard"
          }
        },
        {
          "name": "Missed Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/alerts/missed-payments"
          }
        },
        {
          "name": "Monthly Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/analytics/monthly"
          }
        },
        {
          "name": "Motorcycle Profitability",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/analytics/motorcycles/{{motorcycle_id}}"
          }
        }
      ]
    },
    {
      "name": "Import Export",
      "item": [
        {
          "name": "Export Credentials (Excel)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/export/credentials/excel"
          }
        },
        {
          "name": "Import Credentials (Excel)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "multipart/form-data" }
            ],
            "url": "{{base_url}}/import/credentials/excel",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": [] }]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "rider_id", "value": "" },
    { "key": "motorcycle_id", "value": "" },
    { "key": "payment_id", "value": "" }
  ]
}
